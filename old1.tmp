п»ҝconst handleToggleFavorite = async (generationId: number) => {
    if (!user) {
      toast.error('Please sign in to manage favorites');
      router.push('/auth/signin');
      return;
    }
    
    try {
      // йҚҸе Је№ҸйҚҷж §з¶ӢйҚ“е¶Үж®‘favoriteйҗҳиҲөвӮ¬?      const currentGeneration = generations.find(gen => gen.id === generationId);
      const newFavoriteStatus = !currentGeneration?.is_favorited;
      // Use DataContext mutation and short-circuit legacy fetch
      await setFavorite(generationId, newFavoriteStatus);
      await fetchFavorites(true);
      toast.success('Favorite updated');
      return;
      
      const response = await fetch('/api/me/generations', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
          generationId, 
          isFavorited: newFavoriteStatus 
        }),
      });

      if (!response.ok) {
        const result = await response.json();
        throw new Error(result.error || 'Failed to update favorite');
      }
      
      // жөЈи·Ёж•ӨcontextйҗЁеүҲpdateGenerationйҸӮи§„зЎ¶йҸҮеӯҳжҹҠйҗҳиҲөвӮ¬?      updateGeneration(generationId, { is_favorited: newFavoriteStatus });

      // йҚ’й”ӢжҹҠйҸҖжғ°жЈҢйҚ’жҘ„гҖғ
      await fetchFavorites(true);

      toast.success('Favorite updated');
    } catch (error: any) {
      toast.error(error.message || 'Failed to update favorite');
    }
  };
